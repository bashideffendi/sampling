/**
 * Test untuk cross-ref risk rules.
 * Fokus: positive cases (rule menangkap pola yang seharusnya), negative cases
 * (clean data → 0 hit), dan edge cases (defaultOff rule tanpa context).
 */

import { describe, expect, it } from "vitest";
import type { SP2DRow } from "@/types";
import {
  CROSS_REF_RULES,
  duplicatePayment,
  identicalAmount,
  gapNomorSP2D,
  nilaiExceedPagu,
  vendorNotInMaster,
  crossVendorSameUraianDiffOPD,
  crossUraianSameVendorDiffOPD,
  extractSP2DSeq,
} from "./cross-ref";

// ---------------------------------------------------------------------------
// Test factories
// ---------------------------------------------------------------------------

let __idx = 0;
function row(partial: Partial<SP2DRow>): SP2DRow {
  return {
    no_sp2d: `SP2D-${++__idx}`,
    tgl_sp2d: "2025-01-01",
    nilai: 1_000_000,
    _idx: __idx,
    ...partial,
  };
}

// ---------------------------------------------------------------------------
// Registry sanity
// ---------------------------------------------------------------------------

describe("CROSS_REF_RULES registry", () => {
  it("punya 7 rule dengan id unik", () => {
    expect(CROSS_REF_RULES).toHaveLength(7);
    const ids = CROSS_REF_RULES.map((r) => r.id);
    expect(new Set(ids).size).toBe(7);
  });

  it("semua rule kategori = cross_ref", () => {
    for (const r of CROSS_REF_RULES) {
      expect(r.category).toBe("cross_ref");
    }
  });

  it("rule butuh enrichment defaultOff", () => {
    expect(nilaiExceedPagu.defaultOn).toBe(false);
    expect(vendorNotInMaster.defaultOn).toBe(false);
    expect(gapNomorSP2D.defaultOn).toBe(false);
  });

  it("rule generik defaultOn", () => {
    expect(duplicatePayment.defaultOn).toBe(true);
    expect(identicalAmount.defaultOn).toBe(true);
    expect(crossVendorSameUraianDiffOPD.defaultOn).toBe(true);
    expect(crossUraianSameVendorDiffOPD.defaultOn).toBe(true);
  });
});

// ---------------------------------------------------------------------------
// extractSP2DSeq helper
// ---------------------------------------------------------------------------

describe("extractSP2DSeq", () => {
  it("parse format SIPD ambil running number, bukan tahun", () => {
    expect(extractSP2DSeq("35.27/04.0/000123/LS/2025")).toBe(123);
    expect(extractSP2DSeq("00456/SP2D/LS/2025")).toBe(456);
    expect(extractSP2DSeq("SP2D-00789-2025")).toBe(789);
  });

  it("return null untuk format tanpa running number", () => {
    expect(extractSP2DSeq("")).toBeNull();
    expect(extractSP2DSeq("ABC")).toBeNull();
  });
});

// ---------------------------------------------------------------------------
// Rule 1: duplicate_payment
// ---------------------------------------------------------------------------

describe("duplicatePayment", () => {
  it("flag 2 SP2D vendor+nilai+uraian sama dalam 30 hari", () => {
    __idx = 0;
    const rows = [
      row({
        penyedia: "CV Maju Jaya",
        nilai: 50_000_000,
        uraian: "Pengadaan ATK semester 1",
        tgl_sp2d: "2025-03-01",
      }),
      row({
        penyedia: "CV Maju Jaya",
        nilai: 50_000_000,
        uraian: "Pengadaan ATK semester 1",
        tgl_sp2d: "2025-03-20",
      }),
      row({
        penyedia: "CV Lain",
        nilai: 10_000_000,
        uraian: "Catering rapat",
        tgl_sp2d: "2025-03-15",
      }),
    ];
    const hits = duplicatePayment.run(rows, {});
    expect(hits).toHaveLength(2);
    expect(hits[0].ruleId).toBe("duplicate_payment");
    expect(hits[0].severity).toBe("high");
  });

  it("GAK flag kalau jarak hari > window", () => {
    __idx = 0;
    const rows = [
      row({
        penyedia: "CV Maju Jaya",
        nilai: 50_000_000,
        uraian: "Pengadaan ATK",
        tgl_sp2d: "2025-01-01",
      }),
      row({
        penyedia: "CV Maju Jaya",
        nilai: 50_000_000,
        uraian: "Pengadaan ATK",
        tgl_sp2d: "2025-06-01",
      }),
    ];
    const hits = duplicatePayment.run(rows, {});
    expect(hits).toHaveLength(0);
  });

  it("GAK flag kalau vendor beda", () => {
    __idx = 0;
    const rows = [
      row({ penyedia: "CV A", nilai: 50_000_000, uraian: "ATK", tgl_sp2d: "2025-03-01" }),
      row({ penyedia: "CV B", nilai: 50_000_000, uraian: "ATK", tgl_sp2d: "2025-03-05" }),
    ];
    const hits = duplicatePayment.run(rows, {});
    expect(hits).toHaveLength(0);
  });
});

// ---------------------------------------------------------------------------
// Rule 2: identical_amount
// ---------------------------------------------------------------------------

describe("identicalAmount", () => {
  it("flag 3+ SP2D dengan nilai persis sama > Rp 10jt", () => {
    __idx = 0;
    const rows = [
      row({ nilai: 25_000_000, penyedia: "A" }),
      row({ nilai: 25_000_000, penyedia: "B" }),
      row({ nilai: 25_000_000, penyedia: "C" }),
      row({ nilai: 99_000_000, penyedia: "D" }),
    ];
    const hits = identicalAmount.run(rows, {});
    expect(hits).toHaveLength(3);
    expect(hits.every((h) => h.ruleId === "identical_amount")).toBe(true);
  });

  it("GAK flag kalau cuma 2 instance (default minInstance=3)", () => {
    __idx = 0;
    const rows = [
      row({ nilai: 25_000_000 }),
      row({ nilai: 25_000_000 }),
    ];
    const hits = identicalAmount.run(rows, {});
    expect(hits).toHaveLength(0);
  });

  it("skip nilai < Rp 10jt (trivial)", () => {
    __idx = 0;
    const rows = [
      row({ nilai: 1_000_000 }),
      row({ nilai: 1_000_000 }),
      row({ nilai: 1_000_000 }),
    ];
    const hits = identicalAmount.run(rows, {});
    expect(hits).toHaveLength(0);
  });
});

// ---------------------------------------------------------------------------
// Rule 3: gap_nomor_sp2d
// ---------------------------------------------------------------------------

describe("gapNomorSP2D", () => {
  it("flag gap > 5 dalam SKPD sama", () => {
    __idx = 0;
    const rows = [
      row({ no_sp2d: "00100/SP2D/LS/2025", skpd: "Dinas Pendidikan" }),
      row({ no_sp2d: "00101/SP2D/LS/2025", skpd: "Dinas Pendidikan" }),
      // gap 15 di sini
      row({ no_sp2d: "00116/SP2D/LS/2025", skpd: "Dinas Pendidikan" }),
    ];
    const hits = gapNomorSP2D.run(rows, {});
    expect(hits).toHaveLength(1);
    expect(hits[0].evidence).toMatchObject({ gap: 15 });
  });

  it("GAK flag gap <= threshold", () => {
    __idx = 0;
    const rows = [
      row({ no_sp2d: "00100/SP2D/LS/2025", skpd: "Dinas A" }),
      row({ no_sp2d: "00103/SP2D/LS/2025", skpd: "Dinas A" }),
    ];
    const hits = gapNomorSP2D.run(rows, {});
    expect(hits).toHaveLength(0);
  });

  it("hormati override threshold", () => {
    __idx = 0;
    const rows = [
      row({ no_sp2d: "00100/SP2D/LS/2025", skpd: "Dinas A" }),
      row({ no_sp2d: "00103/SP2D/LS/2025", skpd: "Dinas A" }),
    ];
    const hits = gapNomorSP2D.run(rows, { gapNomorThreshold: 2 });
    expect(hits).toHaveLength(1);
  });
});

// ---------------------------------------------------------------------------
// Rule 4: nilai_exceed_pagu
// ---------------------------------------------------------------------------

describe("nilaiExceedPagu", () => {
  it("return [] tanpa paguMap (defaultOff guard)", () => {
    __idx = 0;
    const rows = [row({ skpd: "Dinas A", kode_rek: "5.1.02.01", nilai: 100_000_000 })];
    expect(nilaiExceedPagu.run(rows, {})).toHaveLength(0);
  });

  it("flag kalau total realisasi > pagu", () => {
    __idx = 0;
    const rows = [
      row({ skpd: "Dinas A", kode_rek: "5.1.02.01", nilai: 60_000_000 }),
      row({ skpd: "Dinas A", kode_rek: "5.1.02.01", nilai: 60_000_000 }),
    ];
    const paguMap = new Map<string, number>([
      ["dinas a|5.1.02.01", 100_000_000],
    ]);
    const hits = nilaiExceedPagu.run(rows, { paguMap });
    expect(hits).toHaveLength(2);
    expect(hits[0].evidence).toMatchObject({ exceed: 20_000_000 });
  });

  it("GAK flag kalau total <= pagu", () => {
    __idx = 0;
    const rows = [row({ skpd: "Dinas A", kode_rek: "5.1.02.01", nilai: 50_000_000 })];
    const paguMap = new Map<string, number>([
      ["dinas a|5.1.02.01", 100_000_000],
    ]);
    expect(nilaiExceedPagu.run(rows, { paguMap })).toHaveLength(0);
  });
});

// ---------------------------------------------------------------------------
// Rule 5: vendor_not_in_master
// ---------------------------------------------------------------------------

describe("vendorNotInMaster", () => {
  it("return [] tanpa masterVendorNPWP", () => {
    __idx = 0;
    const rows = [row({ npwp: "012345678901234" })];
    expect(vendorNotInMaster.run(rows, {})).toHaveLength(0);
  });

  it("flag NPWP yang gak ada di master", () => {
    __idx = 0;
    const rows = [
      row({ npwp: "01.234.567.8-901.234", penyedia: "CV X" }), // 15 digit
      row({ npwp: "99.999.999.9-999.999", penyedia: "CV Y" }),
    ];
    const master = new Set(["012345678901234"]);
    const hits = vendorNotInMaster.run(rows, { masterVendorNPWP: master });
    expect(hits).toHaveLength(1);
    expect(hits[0].evidence).toMatchObject({ vendor: "CV Y" });
  });

  it("terima NPWP 16 digit (NIK WP OP, PMK-112/2022)", () => {
    __idx = 0;
    const rows = [
      row({ npwp: "1234567890123456", penyedia: "WP OP" }), // 16 digit
    ];
    const master = new Set<string>(); // master kosong → harus ke-flag
    const hits = vendorNotInMaster.run(rows, { masterVendorNPWP: new Set(["x"]) });
    expect(hits).toHaveLength(1);
    expect(hits[0].evidence).toMatchObject({ npwp: "1234567890123456" });
    // Sanity: master kosong harusnya skip rule (guard size===0)
    expect(vendorNotInMaster.run(rows, { masterVendorNPWP: master })).toHaveLength(0);
  });

  it("skip NPWP dengan panjang aneh (bukan 15/16 digit)", () => {
    __idx = 0;
    const rows = [row({ npwp: "12345", penyedia: "X" })];
    const master = new Set(["xxx"]);
    expect(vendorNotInMaster.run(rows, { masterVendorNPWP: master })).toHaveLength(0);
  });
});

// ---------------------------------------------------------------------------
// Rule 6: cross_vendor_same_uraian_diff_opd
// ---------------------------------------------------------------------------

describe("crossVendorSameUraianDiffOPD", () => {
  it("flag vendor sama, uraian serupa, OPD beda dalam 30 hari", () => {
    __idx = 0;
    const rows = [
      row({
        penyedia: "CV Konsultan",
        uraian: "Jasa konsultansi perencanaan",
        skpd: "Dinas PU",
        tgl_sp2d: "2025-04-01",
      }),
      row({
        penyedia: "CV Konsultan",
        uraian: "Jasa konsultansi perencanaan",
        skpd: "Dinas Kesehatan",
        tgl_sp2d: "2025-04-15",
      }),
    ];
    const hits = crossVendorSameUraianDiffOPD.run(rows, {});
    expect(hits).toHaveLength(2);
    expect(hits[0].evidence).toMatchObject({ opdCount: 2 });
  });

  it("GAK flag kalau OPD sama", () => {
    __idx = 0;
    const rows = [
      row({
        penyedia: "CV X",
        uraian: "Pengadaan ATK",
        skpd: "Dinas PU",
        tgl_sp2d: "2025-04-01",
      }),
      row({
        penyedia: "CV X",
        uraian: "Pengadaan ATK",
        skpd: "Dinas PU",
        tgl_sp2d: "2025-04-10",
      }),
    ];
    expect(crossVendorSameUraianDiffOPD.run(rows, {})).toHaveLength(0);
  });
});

// ---------------------------------------------------------------------------
// Rule 7: cross_uraian_same_vendor_diff_opd (templat)
// ---------------------------------------------------------------------------

describe("crossUraianSameVendorDiffOPD", () => {
  it("flag uraian identik di 2+ OPD beda (vendor boleh beda)", () => {
    __idx = 0;
    const rows = [
      row({
        uraian: "Belanja Modal Peralatan Komputer",
        skpd: "Dinas A",
        penyedia: "CV X",
      }),
      row({
        uraian: "Belanja Modal Peralatan Komputer",
        skpd: "Dinas B",
        penyedia: "CV Y",
      }),
    ];
    const hits = crossUraianSameVendorDiffOPD.run(rows, {});
    expect(hits).toHaveLength(2);
    expect(hits[0].severity).toBe("low");
  });

  it("skip uraian terlalu pendek (<10 char)", () => {
    __idx = 0;
    const rows = [
      row({ uraian: "ATK", skpd: "Dinas A" }),
      row({ uraian: "ATK", skpd: "Dinas B" }),
    ];
    expect(crossUraianSameVendorDiffOPD.run(rows, {})).toHaveLength(0);
  });
});
