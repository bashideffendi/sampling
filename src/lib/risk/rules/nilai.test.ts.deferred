import { describe, it, expect } from "vitest";
import type { SP2DRow } from "@/types";
import {
  classifyPengadaan,
  isExemptAccount,
  isRoundNumber,
  ruleNearPL200jtBarangPKJasaLainnya,
  ruleNearPL100jtJasaKonsultansi,
  ruleNearSPKKuitansi50jt,
  ruleSplitPaket,
  ruleRoundNumber,
  NILAI_RULES,
} from "./nilai";

function row(partial: Partial<SP2DRow> & { _idx: number; nilai: number }): SP2DRow {
  return {
    no_sp2d: partial.no_sp2d ?? `SP2D-${partial._idx}`,
    tgl_sp2d: partial.tgl_sp2d ?? "2025-06-01",
    nilai: partial.nilai,
    skpd: partial.skpd,
    kode_rek: partial.kode_rek,
    uraian: partial.uraian,
    penyedia: partial.penyedia,
    npwp: partial.npwp,
    bank: partial.bank,
    no_spm: partial.no_spm,
    kegiatan: partial.kegiatan,
    sub_kegiatan: partial.sub_kegiatan,
    jenis_spm: partial.jenis_spm,
    program: partial.program,
    _idx: partial._idx,
  };
}

describe("helpers", () => {
  it("classifyPengadaan: 522/523 = barang_pk_jasa_lainnya, 524 = konsultansi, lainnya = unknown", () => {
    expect(classifyPengadaan("5.2.2.01.01")).toBe("barang_pk_jasa_lainnya");
    expect(classifyPengadaan("523.05")).toBe("barang_pk_jasa_lainnya");
    expect(classifyPengadaan("5.2.4.01")).toBe("konsultansi");
    expect(classifyPengadaan("5.1.01")).toBe("unknown");
    expect(classifyPengadaan(undefined)).toBe("unknown");
  });

  it("isExemptAccount: 56xx hibah / 57xx bansos / honor / perjadin", () => {
    expect(isExemptAccount(row({ _idx: 1, nilai: 100, kode_rek: "5.6.01" }))).toBe(true); // hibah
    expect(isExemptAccount(row({ _idx: 2, nilai: 100, kode_rek: "5.7.02" }))).toBe(true); // bansos
    expect(
      isExemptAccount(row({ _idx: 3, nilai: 100, uraian: "Honorarium narasumber" })),
    ).toBe(true);
    expect(
      isExemptAccount(row({ _idx: 4, nilai: 100, uraian: "Perjalanan Dinas Dalam Daerah" })),
    ).toBe(true);
    expect(isExemptAccount(row({ _idx: 5, nilai: 100, kode_rek: "5.2.2" }))).toBe(false);
  });

  it("isRoundNumber: kelipatan Rp 1 jt", () => {
    expect(isRoundNumber(50_000_000)).toBe(true);
    expect(isRoundNumber(123_000_000)).toBe(true);
    expect(isRoundNumber(49_999_999)).toBe(false);
    expect(isRoundNumber(50_500_000)).toBe(false);
    expect(isRoundNumber(0)).toBe(false);
  });
});

describe("ruleNearPL200jtBarangPKJasaLainnya", () => {
  const rows: SP2DRow[] = [
    row({ _idx: 1, nilai: 185_000_000, kode_rek: "5.2.2.01" }), // hit (barang)
    row({ _idx: 2, nilai: 200_000_000, kode_rek: "5.2.3.01" }), // hit (modal/PK) — pas di batas inclusive
    row({ _idx: 3, nilai: 179_999_999, kode_rek: "5.2.2.01" }), // miss — di bawah 180jt
    row({ _idx: 4, nilai: 200_000_001, kode_rek: "5.2.2.01" }), // miss — di atas 200jt
    row({ _idx: 5, nilai: 195_000_000, kode_rek: "5.2.4.01" }), // miss — ini konsultansi, bukan kategori ini
    row({ _idx: 6, nilai: 190_000_000, kode_rek: undefined }), // hit dgn note 'uncertain'
  ];
  const hits = ruleNearPL200jtBarangPKJasaLainnya.run(rows);
  it("flag 180–200 jt untuk barang/PK; jangan flag konsultansi", () => {
    const idxs = hits.map((h) => h.row._idx).sort();
    expect(idxs).toEqual([1, 2, 6]);
  });
  it("tandai uncertain untuk kode_rek tidak diketahui", () => {
    const uncertain = hits.find((h) => h.row._idx === 6);
    expect(uncertain?.note).toMatch(/tidak dapat dipastikan/i);
  });
  it("sitasi mengarah ke Perpres 16/2018 jo 12/2021", () => {
    expect(ruleNearPL200jtBarangPKJasaLainnya.citation).toMatch(/Perpres 16\/2018/);
  });
});

describe("ruleNearPL100jtJasaKonsultansi", () => {
  const rows: SP2DRow[] = [
    row({ _idx: 1, nilai: 95_000_000, kode_rek: "5.2.4.01" }), // hit
    row({ _idx: 2, nilai: 100_000_000, kode_rek: "5.2.4.99" }), // hit (batas inclusive)
    row({ _idx: 3, nilai: 89_999_999, kode_rek: "5.2.4.01" }), // miss — di bawah 90 jt
    row({ _idx: 4, nilai: 95_000_000, kode_rek: "5.2.2.01" }), // miss — ini barang, bukan konsultansi
    row({ _idx: 5, nilai: 100_000_001, kode_rek: "5.2.4.01" }), // miss — di atas 100 jt
  ];
  const hits = ruleNearPL100jtJasaKonsultansi.run(rows);
  it("flag 90–100 jt hanya untuk kode_rek 524", () => {
    const idxs = hits.map((h) => h.row._idx).sort();
    expect(idxs).toEqual([1, 2]);
  });
});

describe("ruleNearSPKKuitansi50jt", () => {
  const rows: SP2DRow[] = [
    row({ _idx: 1, nilai: 47_500_000 }), // hit
    row({ _idx: 2, nilai: 50_000_000 }), // hit (batas inclusive)
    row({ _idx: 3, nilai: 44_999_999 }), // miss — di bawah 45 jt
    row({ _idx: 4, nilai: 50_000_001 }), // miss — di atas 50 jt
  ];
  const hits = ruleNearSPKKuitansi50jt.run(rows);
  it("flag 45–50 jt", () => {
    expect(hits.map((h) => h.row._idx).sort()).toEqual([1, 2]);
  });
  it("TIDAK mengutip Perpres 16/2018 (citation = null) — Rp 50jt bukan threshold Perpres", () => {
    expect(ruleNearSPKKuitansi50jt.citation).toBeNull();
  });
  it("label tidak menyebut 'PL'", () => {
    expect(ruleNearSPKKuitansi50jt.label).not.toMatch(/PL\b/);
    expect(ruleNearSPKKuitansi50jt.label).toMatch(/SPK|Kuitansi/i);
  });
});

describe("ruleSplitPaket", () => {
  it("flag 4 SP2D ke vendor & OPD sama dlm 7 hari yg totalnya > 200 jt", () => {
    const rows: SP2DRow[] = [
      row({
        _idx: 1,
        nilai: 60_000_000,
        tgl_sp2d: "2025-06-02",
        penyedia: "CV ABC",
        skpd: "Dinas X",
      }),
      row({
        _idx: 2,
        nilai: 70_000_000,
        tgl_sp2d: "2025-06-04",
        penyedia: "CV ABC",
        skpd: "Dinas X",
      }),
      row({
        _idx: 3,
        nilai: 60_000_000,
        tgl_sp2d: "2025-06-06",
        penyedia: "CV ABC",
        skpd: "Dinas X",
      }),
      row({
        _idx: 4,
        nilai: 50_000_000,
        tgl_sp2d: "2025-06-08",
        penyedia: "CV ABC",
        skpd: "Dinas X",
      }),
      // di luar jendela 7 hari dari _idx 1, tapi gabung dgn _idx 2/3/4 — masih ke-flag
    ];
    const hits = ruleSplitPaket.run(rows);
    const flaggedIdxs = hits.map((h) => h.row._idx).sort();
    expect(flaggedIdxs).toEqual([1, 2, 3, 4]);
    expect(hits[0].note).toMatch(/Rp\s/);
  });

  it("JANGAN flag kalau ada satu SP2D tunggal >= 200 jt (itu tender besar, bukan split)", () => {
    const rows: SP2DRow[] = [
      row({
        _idx: 1,
        nilai: 250_000_000,
        tgl_sp2d: "2025-06-02",
        penyedia: "CV BIG",
        skpd: "Dinas Y",
      }),
      row({
        _idx: 2,
        nilai: 30_000_000,
        tgl_sp2d: "2025-06-04",
        penyedia: "CV BIG",
        skpd: "Dinas Y",
      }),
    ];
    expect(ruleSplitPaket.run(rows)).toEqual([]);
  });

  it("JANGAN flag kalau total <= 200 jt walau banyak transaksi", () => {
    const rows: SP2DRow[] = [
      row({
        _idx: 1,
        nilai: 40_000_000,
        tgl_sp2d: "2025-06-02",
        penyedia: "CV C",
        skpd: "Dinas Z",
      }),
      row({
        _idx: 2,
        nilai: 50_000_000,
        tgl_sp2d: "2025-06-03",
        penyedia: "CV C",
        skpd: "Dinas Z",
      }),
      row({
        _idx: 3,
        nilai: 60_000_000,
        tgl_sp2d: "2025-06-05",
        penyedia: "CV C",
        skpd: "Dinas Z",
      }),
    ];
    expect(ruleSplitPaket.run(rows)).toEqual([]);
  });

  it("JANGAN flag kalau vendor sama tapi OPD beda (sub-key beda)", () => {
    const rows: SP2DRow[] = [
      row({
        _idx: 1,
        nilai: 120_000_000,
        tgl_sp2d: "2025-06-02",
        penyedia: "CV D",
        skpd: "Dinas A",
      }),
      row({
        _idx: 2,
        nilai: 120_000_000,
        tgl_sp2d: "2025-06-04",
        penyedia: "CV D",
        skpd: "Dinas B",
      }),
    ];
    expect(ruleSplitPaket.run(rows)).toEqual([]);
  });

  it("sliding window: transaksi yg di luar 7 hari TIDAK dihitung di window lama", () => {
    const rows: SP2DRow[] = [
      row({
        _idx: 1,
        nilai: 150_000_000,
        tgl_sp2d: "2025-06-01",
        penyedia: "CV E",
        skpd: "Dinas Q",
      }),
      // 10 hari berikutnya — window baru
      row({
        _idx: 2,
        nilai: 100_000_000,
        tgl_sp2d: "2025-06-20",
        penyedia: "CV E",
        skpd: "Dinas Q",
      }),
    ];
    expect(ruleSplitPaket.run(rows)).toEqual([]);
  });
});

describe("ruleRoundNumber", () => {
  it("flag angka bulat ≥ 50 jt, EXCLUDE hibah/bansos/honor/perjadin", () => {
    const rows: SP2DRow[] = [
      row({ _idx: 1, nilai: 75_000_000, kode_rek: "5.2.2.01" }), // hit
      row({ _idx: 2, nilai: 100_000_000, kode_rek: "5.2.3.05" }), // hit
      row({ _idx: 3, nilai: 75_123_456, kode_rek: "5.2.2.01" }), // miss — bukan bulat
      row({ _idx: 4, nilai: 49_000_000, kode_rek: "5.2.2.01" }), // miss — di bawah Rp 50 jt
      row({ _idx: 5, nilai: 500_000_000, kode_rek: "5.6.01" }), // miss — hibah
      row({ _idx: 6, nilai: 200_000_000, kode_rek: "5.7.02" }), // miss — bansos
      row({ _idx: 7, nilai: 60_000_000, uraian: "Honorarium tim teknis" }), // miss — honor
      row({ _idx: 8, nilai: 80_000_000, uraian: "Perjalanan Dinas Luar Daerah" }), // miss — perjadin
    ];
    const idxs = ruleRoundNumber.run(rows).map((h) => h.row._idx).sort();
    expect(idxs).toEqual([1, 2]);
  });

  it("severity = medium dan defaultOn", () => {
    expect(ruleRoundNumber.severity).toBe("medium");
    expect(ruleRoundNumber.defaultOn).toBe(true);
  });
});

describe("NILAI_RULES registry", () => {
  it("semua 5 rule terdaftar, kategori 'nilai', defaultOn true", () => {
    expect(NILAI_RULES).toHaveLength(5);
    for (const r of NILAI_RULES) {
      expect(r.category).toBe("nilai");
      expect(r.defaultOn).toBe(true);
      expect(r.id.startsWith("nilai_")).toBe(true);
    }
  });

  it("id unik", () => {
    const ids = NILAI_RULES.map((r) => r.id);
    expect(new Set(ids).size).toBe(ids.length);
  });
});
