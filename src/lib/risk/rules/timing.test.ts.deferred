/**
 * Test timing rules — fokus ke date-boundary correctness (year-end, weekend,
 * pre-libur) dan exclusion LS gaji.
 *
 * Hari kalender 2025 referensi (cross-check):
 * - 2025-12-31 = Wednesday
 * - 2025-12-25 = Thursday (Natal)
 * - 2025-12-24 = Wednesday (1 hari sebelum Natal → pre-libur)
 * - 2025-12-06 = Saturday
 * - 2025-12-07 = Sunday
 * - 2025-11-30 = Sunday (bukan Desember)
 * - 2025-03-29 = Saturday (Nyepi)
 * - 2025-03-28 = Friday (1 hari sebelum Nyepi → pre-libur)
 */

import { describe, it, expect } from "vitest";
import type { SP2DRow } from "@/types";
import {
  parseISODate,
  dayOfWeek,
  isWeekend,
  isDecember,
  isYearEndCritical,
  isRutinGajiTunjangan,
  isPreLiburPanjang,
  timing_year_end_spike,
  timing_year_end_critical,
  timing_weekend_holiday,
  timing_before_dpa,
  timing_pre_libur_panjang,
  TIMING_RULES,
} from "./timing";

// Helper bikin SP2DRow ringkas — overridable per-test.
function mkRow(over: Partial<SP2DRow> = {}): SP2DRow {
  return {
    no_sp2d: "00001",
    tgl_sp2d: "2025-06-15",
    nilai: 1_000_000,
    _idx: 0,
    ...over,
  };
}

// ──────────────────────────────────────────────────────────────────────────────
// Helper functions
// ──────────────────────────────────────────────────────────────────────────────

describe("parseISODate", () => {
  it("parses valid yyyy-mm-dd", () => {
    expect(parseISODate("2025-12-31")).toEqual({ y: 2025, m: 12, d: 31 });
    expect(parseISODate("2025-01-01")).toEqual({ y: 2025, m: 1, d: 1 });
  });

  it("rejects invalid format & out-of-range", () => {
    expect(parseISODate("")).toBeNull();
    expect(parseISODate(undefined)).toBeNull();
    expect(parseISODate("31-12-2025")).toBeNull();
    expect(parseISODate("2025-13-01")).toBeNull(); // bulan invalid
    expect(parseISODate("2025-12-32")).toBeNull(); // tanggal invalid
    expect(parseISODate("2025-12-1")).toBeNull(); // tanpa zero-pad
  });
});

describe("dayOfWeek & isWeekend", () => {
  it("returns correct DOW (TZ-independent)", () => {
    // 2025-12-31 = Wednesday → 3
    expect(dayOfWeek("2025-12-31")).toBe(3);
    // 2025-12-06 = Saturday → 6
    expect(dayOfWeek("2025-12-06")).toBe(6);
    // 2025-12-07 = Sunday → 0
    expect(dayOfWeek("2025-12-07")).toBe(0);
  });

  it("detects weekend correctly", () => {
    expect(isWeekend("2025-12-06")).toBe(true); // Sabtu
    expect(isWeekend("2025-12-07")).toBe(true); // Minggu
    expect(isWeekend("2025-12-31")).toBe(false); // Rabu
    expect(isWeekend("2025-12-25")).toBe(false); // Kamis
  });
});

// ──────────────────────────────────────────────────────────────────────────────
// timing_year_end_spike (Desember)
// ──────────────────────────────────────────────────────────────────────────────

describe("timing_year_end_spike", () => {
  it("flags Desember 1 (boundary)", () => {
    expect(isDecember("2025-12-01")).toBe(true);
    expect(timing_year_end_spike.filter(mkRow({ tgl_sp2d: "2025-12-01" }))).toBe(
      true,
    );
  });

  it("flags Desember 31 (boundary)", () => {
    expect(timing_year_end_spike.filter(mkRow({ tgl_sp2d: "2025-12-31" }))).toBe(
      true,
    );
  });

  it("does NOT flag November 30", () => {
    expect(isDecember("2025-11-30")).toBe(false);
    expect(timing_year_end_spike.filter(mkRow({ tgl_sp2d: "2025-11-30" }))).toBe(
      false,
    );
  });

  it("has correct metadata", () => {
    expect(timing_year_end_spike.category).toBe("timing");
    expect(timing_year_end_spike.severity).toBe("medium");
    expect(timing_year_end_spike.defaultOn).toBe(true);
  });
});

// ──────────────────────────────────────────────────────────────────────────────
// timing_year_end_critical (Des 25-31)
// ──────────────────────────────────────────────────────────────────────────────

describe("timing_year_end_critical", () => {
  it("flags Des 25 (boundary lower)", () => {
    expect(isYearEndCritical("2025-12-25")).toBe(true);
    expect(
      timing_year_end_critical.filter(mkRow({ tgl_sp2d: "2025-12-25" })),
    ).toBe(true);
  });

  it("flags Des 31 (boundary upper)", () => {
    expect(isYearEndCritical("2025-12-31")).toBe(true);
    expect(
      timing_year_end_critical.filter(mkRow({ tgl_sp2d: "2025-12-31" })),
    ).toBe(true);
  });

  it("does NOT flag Des 24 (just below window)", () => {
    expect(isYearEndCritical("2025-12-24")).toBe(false);
    expect(
      timing_year_end_critical.filter(mkRow({ tgl_sp2d: "2025-12-24" })),
    ).toBe(false);
  });

  it("does NOT flag Nov 30 or Jan 1", () => {
    expect(isYearEndCritical("2025-11-30")).toBe(false);
    expect(isYearEndCritical("2026-01-01")).toBe(false);
  });

  it("has high severity + defaultOn", () => {
    expect(timing_year_end_critical.severity).toBe("high");
    expect(timing_year_end_critical.defaultOn).toBe(true);
  });
});

// ──────────────────────────────────────────────────────────────────────────────
// timing_weekend_holiday (+ exclusion gaji)
// ──────────────────────────────────────────────────────────────────────────────

describe("timing_weekend_holiday", () => {
  it("flags weekday=false / weekend=true non-gaji", () => {
    // 2025-12-06 = Sabtu, uraian belanja barang
    const row = mkRow({
      tgl_sp2d: "2025-12-06",
      uraian: "Belanja ATK kantor",
    });
    expect(timing_weekend_holiday.filter(row)).toBe(true);
  });

  it("does NOT flag weekday non-gaji", () => {
    const row = mkRow({
      tgl_sp2d: "2025-12-31", // Rabu
      uraian: "Belanja ATK kantor",
    });
    expect(timing_weekend_holiday.filter(row)).toBe(false);
  });

  it("EXCLUDES LS gaji rutin meskipun weekend (via jenis_spm)", () => {
    const row = mkRow({
      tgl_sp2d: "2025-12-06", // Sabtu
      jenis_spm: "LS Gaji",
      uraian: "Pembayaran gaji induk Desember 2025",
    });
    expect(isRutinGajiTunjangan(row)).toBe(true);
    expect(timing_weekend_holiday.filter(row)).toBe(false);
  });

  it("EXCLUDES tunjangan / tukin / TPP rutin via uraian", () => {
    const rTukin = mkRow({
      tgl_sp2d: "2025-12-07", // Minggu
      uraian: "Pembayaran TUKIN bulan November",
    });
    expect(isRutinGajiTunjangan(rTukin)).toBe(true);
    expect(timing_weekend_holiday.filter(rTukin)).toBe(false);

    const rTpp = mkRow({
      tgl_sp2d: "2025-12-07",
      uraian: "Tambahan Penghasilan Pegawai November 2025",
    });
    expect(timing_weekend_holiday.filter(rTpp)).toBe(false);
  });

  it("does NOT exclude LS pengadaan (kata LS tanpa gaji) di weekend", () => {
    // Penting: 'LS pengadaan barang' di weekend tetap flag (bukan rutin gaji).
    const row = mkRow({
      tgl_sp2d: "2025-12-06", // Sabtu
      jenis_spm: "LS",
      uraian: "Pembayaran termin II pengadaan komputer",
    });
    expect(isRutinGajiTunjangan(row)).toBe(false);
    expect(timing_weekend_holiday.filter(row)).toBe(true);
  });

  it("is defaultOff (banyak false positive gaji rutin)", () => {
    expect(timing_weekend_holiday.defaultOn).toBe(false);
  });
});

// ──────────────────────────────────────────────────────────────────────────────
// timing_before_dpa (placeholder)
// ──────────────────────────────────────────────────────────────────────────────

describe("timing_before_dpa", () => {
  it("is a defaultOff placeholder (no DPA data yet)", () => {
    expect(timing_before_dpa.defaultOn).toBe(false);
    expect(timing_before_dpa.severity).toBe("high");
    // Placeholder predicate selalu false — engine skip rule ini sampe data DPA siap.
    expect(timing_before_dpa.filter(mkRow({ tgl_sp2d: "2025-01-15" }))).toBe(
      false,
    );
    expect(timing_before_dpa.filter(mkRow({ tgl_sp2d: "2025-12-31" }))).toBe(
      false,
    );
  });
});

// ──────────────────────────────────────────────────────────────────────────────
// timing_pre_libur_panjang
// ──────────────────────────────────────────────────────────────────────────────

describe("timing_pre_libur_panjang", () => {
  it("flags 1 hari sebelum Natal (Des 24 → Des 25)", () => {
    expect(isPreLiburPanjang("2025-12-24")).toBe(true);
    expect(
      timing_pre_libur_panjang.filter(mkRow({ tgl_sp2d: "2025-12-24" })),
    ).toBe(true);
  });

  it("flags 3 hari sebelum Idul Fitri (Mar 28 → Mar 31)", () => {
    expect(isPreLiburPanjang("2025-03-28")).toBe(true);
  });

  it("flags 2 hari sebelum Kemerdekaan (Aug 15 → Aug 17)", () => {
    expect(isPreLiburPanjang("2025-08-15")).toBe(true);
  });

  it("does NOT flag 4 hari sebelum libur (di luar window)", () => {
    // 4 hari sebelum 17 Agt = 13 Agt → di luar window
    expect(isPreLiburPanjang("2025-08-13")).toBe(false);
    expect(
      timing_pre_libur_panjang.filter(mkRow({ tgl_sp2d: "2025-08-13" })),
    ).toBe(false);
  });

  it("does NOT flag tanggal merah itu sendiri (diff = 0)", () => {
    // 25 Des = Natal, bukan PRE-libur
    expect(isPreLiburPanjang("2025-12-25")).toBe(false);
  });

  it("does NOT flag tanggal random tengah tahun", () => {
    expect(isPreLiburPanjang("2025-07-15")).toBe(false);
  });

  it("is defaultOff + low severity (banyak legit: THR, gaji-13, dst)", () => {
    expect(timing_pre_libur_panjang.defaultOn).toBe(false);
    expect(timing_pre_libur_panjang.severity).toBe("low");
  });
});

// ──────────────────────────────────────────────────────────────────────────────
// Registry
// ──────────────────────────────────────────────────────────────────────────────

describe("TIMING_RULES registry", () => {
  it("contains all 5 timing rules with unique IDs", () => {
    expect(TIMING_RULES).toHaveLength(5);
    const ids = TIMING_RULES.map((r) => r.id);
    expect(new Set(ids).size).toBe(5);
    expect(ids).toContain("timing_year_end_spike");
    expect(ids).toContain("timing_year_end_critical");
    expect(ids).toContain("timing_weekend_holiday");
    expect(ids).toContain("timing_before_dpa");
    expect(ids).toContain("timing_pre_libur_panjang");
  });

  it("all rules are category=timing", () => {
    for (const r of TIMING_RULES) expect(r.category).toBe("timing");
  });

  it("all rule IDs are snake_case", () => {
    for (const r of TIMING_RULES) {
      expect(r.id).toMatch(/^[a-z][a-z0-9_]*$/);
    }
  });

  it("no rule cites Perpres for Rp 50jt threshold (timing rules don't cite Perpres at all)", () => {
    // Sanity: timing rules tidak punya citation (semuanya empirical, bukan regulatory)
    for (const r of TIMING_RULES) {
      expect(r.citation).toBeUndefined();
    }
  });
});
